# ============================================================
# AutoReadPaper 环境变量配置模板
# 复制本文件为 .env 并填写实际值：cp .env.example .env
# 注意：.env 文件不应提交到 Git 仓库
# ============================================================

# ── n8n 配置 ──────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=your_strong_password_here
# 随机生成的加密密钥，可用: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace_with_32_char_random_hex_string

# ── DeepSeek API ───────────────────────────────────────────
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 可选: deepseek-chat (V3, 性价比高) 或 deepseek-reasoner (R1, 推理强)
DEEPSEEK_MODEL=deepseek-chat

# ── ChromaDB 认证 ──────────────────────────────────────────
# 自定义 Token，用于 ChromaDB 认证
CHROMA_AUTH_TOKEN=replace_with_your_chroma_token

# ── Email 推送 (SMTP) ──────────────────────────────────────
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your_email@qq.com
# QQ邮箱需要使用授权码，不是登录密码
EMAIL_SMTP_PASSWORD=your_smtp_auth_code
EMAIL_FROM=your_email@qq.com
# 接收论文推送的邮箱，多个用逗号分隔
EMAIL_TO=recipient@example.com

# ── 企业微信群机器人 ────────────────────────────────────────
# 在企业微信群 → 添加机器人 → 复制 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── 飞书群机器人 ────────────────────────────────────────────
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Telegram Bot ────────────────────────────────────────────
# 通过 @BotFather 创建 Bot 并获取 Token
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 目标 Chat ID（个人或群组）：通过 @userinfobot 获取
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ── GitHub Issues 归档 ─────────────────────────────────────
# 创建一个专用于归档论文的公开/私有仓库
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=paper-archive

# ── PubMed API (可选，不配置则跳过 PubMed 搜索) ──────────
# 从 https://www.ncbi.nlm.nih.gov/account/ 获取，提高请求速率限制
NCBI_API_KEY=

# ── Semantic Scholar API (可选) ────────────────────────────
# 从 https://www.semanticscholar.org/product/api 申请
SEMANTIC_SCHOLAR_API_KEY=
